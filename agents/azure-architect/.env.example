# Azure Deployment Architect — environment template
# Copy to .env (gitignored) and fill from P2 wizard output. Never commit real values.

# --- SignalLayer platform (issued by wizard P2) ---
SL_KEY_ID=slk_xxxxxxxxxxxxxxxx
SL_API_KEY=slk_xxxxxxxxxxxxxxxx:hmac_secret_here
SL_API_BASE_URL=https://aigovern.sandboxhub.co
SL_AI_SYSTEM_ID=

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
ANTHROPIC_MODEL_OPUS=claude-opus-4-7
ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5-20251001

# --- Azure ARM (Reader role on target subscriptions) ---
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TARGET_SUBSCRIPTIONS=

# --- Memory + RAG (P5) ---
MEMORY_BACKEND=noop
RAG_INDEX_NAME=azure-architect-rag
