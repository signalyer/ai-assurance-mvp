# finadvice agent — local CLI calibration env template
# Copy to .env in this directory and fill in. Production path is the
# engine-driven Agent Runner (api/agent_runner.py), which reads the
# engine's own env — this .env is only for `python agents/finadvice/agent.py`
# standalone calibration runs.

# Anthropic
ANTHROPIC_API_KEY=

# SignalLayer SDK (signed transport to the engine)
SL_API_KEY=
SL_KEY_ID=
SL_API_BASE_URL=http://localhost:8000
SL_WORKLOAD_ID=finadvice
